#!/usr/bin/env python3
"""Entry point. Resolves its own location (following symlinks) so the pdxaudit
package sits on the path, then hands off to the CLI. Install with:
    ln -s /path/to/pdx-audit ~/.local/bin/pdx-audit
"""
import os
import sys

sys.path.insert(0, os.path.dirname(os.path.realpath(__file__)))

from pdxaudit.cli import main

if __name__ == "__main__":
    main()
